# ===== isiam store — BO7 & Warzone Edition =====
# Copy this file to .env (local) or set these in Railway Variables tab.

# ---- REQUIRED ----
# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Password to access the control panel (anything you want, make it strong)
PANEL_PASSWORD=admin123

# ---- OPTIONAL ----
# Port (Railway sets this automatically; only set for local dev)
# PORT=3000

# Session secret for cookies (auto-generated if not set)
# SESSION_SECRET=any_random_long_string

# ===== HOW TO GET YOUR DISCORD TOKEN =====
# 1. Go to https://discord.com/developers/applications
# 2. Click "New Application" → name it "isiam store" → Create
# 3. Click "Bot" in the left sidebar → "Add Bot" → Yes, do it
# 4. Under TOKEN, click "Copy" — paste it as DISCORD_TOKEN above
# 5. Under "Privileged Gateway Intents" enable:
#    - Presence Intent
#    - Server Members Intent
#    - Message Content Intent
# 6. Under "OAuth2 → URL Generator" select:
#    - Scopes: bot, applications.commands
#    - Bot Permissions: Administrator (or specific: View Channels, Send Messages,
#      Embed Links, Attach Files, Manage Channels, Manage Messages, Read Message History)
# 7. Open the generated URL → add the bot to your server
